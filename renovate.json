{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:best-practices",
    "group:all",
    "schedule:earlyMondays"
  ],
  "dependencyDashboard": true,
  "prHourlyLimit": 2,
  "prConcurrentLimit": 1,
  "automerge": true,
  "automergeType": "pr",
  "automergeStrategy": "squash",
  "packageRules": [
    {
      "matchPackageNames": [
        "nvidia/cuda",
        "python"
      ],
      "enabled": false
    }
  ]
}
